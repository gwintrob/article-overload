{
  "manifest_version": 3,
  "name": "Article Overload",
  "version": "1.0.0",
  "description": "Get word count, read time, AI-detection score, and key takeaways for long-form X posts. Powered by Claude.",
  "permissions": ["storage", "contextMenus"],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {},
  "host_permissions": ["https://api.anthropic.com/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
